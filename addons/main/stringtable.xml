        </Key>
        <Key ID="STR_FIXICS_HAND_BRAKE_SET">
            <Original>Set Handbrake</Original>
        </Key>
        <Key ID="STR_FIXICS_HAND_BRAKE_STATUS_RELEASED">
            <Original>[FIXICS] Handbrake released.</Original>
        </Key>
        <Key ID="STR_FIXICS_HAND_BRAKE_STATUS_SET">
            <Original>[FIXICS] Handbrake set.</Original>
        </Key>
        <Key ID="STR_FIXICS_LOADED">
            <Original>FIXICS mod loaded.</Original>
        </Key>
        <Key ID="STR_FIXICS_NAME">
            <Original>FIXICS</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_BRAKE_STRENGTH">
            <Original>ABS brake strength</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_BRAKE_STRENGTH_TOOLTIP">
            <Original>Longitudinal braking authority normalized to the original 0.25-second monitor interval.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_DEBUG_LOGGING">
            <Original>ABS debug logging</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_DEBUG_LOGGING_TOOLTIP">
            <Original>Writes ABS braking decisions to the RPT log for SQA diagnostics.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_ENABLED">
            <Original>Enable ABS braking</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_ENABLED_TOOLTIP">
            <Original>Applies FIXICS velocity-level anti-lock braking while the local driver is actively braking.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_LOW_SPEED_CUTOFF">
            <Original>ABS low speed cutoff</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_LOW_SPEED_CUTOFF_TOOLTIP">
            <Original>Speed below which FIXICS ABS stops modulating so braking cannot become an idle handbrake.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_RELEASE_BIAS">
            <Original>ABS release bias</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_RELEASE_BIAS_TOOLTIP">
            <Original>Fraction of requested braking released to reduce lock-like stopping.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_SLOPE_COMPENSATION">
            <Original>ABS slope compensation</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ABS_SLOPE_COMPENSATION_TOOLTIP">
            <Original>Additional braking authority used when braking downhill.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DIRECTION_CHANGE_THRESHOLD">
            <Original>Direction change threshold</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DIRECTION_CHANGE_THRESHOLD_TOOLTIP">
            <Original>Speed in kilometers per hour where opposite drive input finishes service braking and starts the requested direction.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DIRECTION_LAUNCH_VELOCITY">
            <Original>Direction launch velocity</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DIRECTION_LAUNCH_VELOCITY_TOOLTIP">
            <Original>Initial model-space velocity in meters per second applied when drive or reverse takes control near zero speed.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DIRECTION_NEUTRAL_PULSE">
            <Original>Direction neutral pulse</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DIRECTION_NEUTRAL_PULSE_TOOLTIP">
            <Original>Time in seconds that FIXICS holds zero longitudinal velocity before launching into the requested opposite direction.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DISABLE_IDLE_AUTOBRAKE">
            <Original>Disable automatic idle handbrake</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DISABLE_IDLE_AUTOBRAKE_TOOLTIP">
            <Original>Keeps Arma's idle vehicle autobrake disabled while stationary unless the FIXICS ACE handbrake is set.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DRIVER_ASSIST_DEBUG_LOGGING">
            <Original>Driver assist debug logging</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DRIVER_ASSIST_DEBUG_LOGGING_TOOLTIP">
            <Original>Writes native driver assist recommendations and SQF fallback decisions to the RPT log for diagnostics.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DRIVER_CONTROLLER_ENABLED">
            <Original>Enable driver state controller</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DRIVER_CONTROLLER_ENABLED_TOOLTIP">
            <Original>Uses FIXICS drive, service brake, reverse, coast, and handbrake states for the local player driver.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DRIVER_CONTROLLER_INTERVAL">
            <Original>Driver controller interval</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_DRIVER_CONTROLLER_INTERVAL_TOOLTIP">
            <Original>Minimum time in seconds between local driver controller updates.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_HANDBRAKE_INPUT_HOLD">
            <Original>Hold</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_HANDBRAKE_INPUT_MODE">
            <Original>X handbrake mode</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_HANDBRAKE_INPUT_MODE_TOOLTIP">
            <Original>Hold applies a temporary handbrake while X is held. Toggle switches the same persistent handbrake used by ACE interactions.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_HANDBRAKE_INPUT_TOGGLE">
            <Original>Toggle</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_NATIVE_DRIVER_ASSIST">
            <Original>Enable native driver assist advisor</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_NATIVE_DRIVER_ASSIST_TOOLTIP">
            <Original>Uses the optional FIXICSPhysics extension for driver-control recommendations. SQF remains responsible for applying vehicle changes.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_NATIVE_SLOPE_CONTROL">
            <Original>Enable native slope control</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_NATIVE_SLOPE_CONTROL_TOOLTIP">
            <Original>Uses the optional FIXICSPhysics native extension for slope rollback recommendations. Leave disabled unless the extension binary is installed.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_ACTIVATION_BANK">
            <Original>Roll activation bank</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_ACTIVATION_BANK_TOOLTIP">
            <Original>Server-global bank angle in degrees before roll stability can add vertical correction. This targets roll, not steering.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_ACTIVATION_RATE">
            <Original>Roll activation rate</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_ACTIVATION_RATE_TOOLTIP">
            <Original>Server-global bank-rate threshold in degrees per second before roll stability reacts to fast roll changes.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_AIRBORNE_GRACE">
            <Original>Roll airborne grace</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_AIRBORNE_GRACE_TOOLTIP">
            <Original>Server-global time in seconds after losing ground contact where roll correction may continue briefly.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_MAXIMUM_CORRECTION">
            <Original>Roll maximum correction</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_MAXIMUM_CORRECTION_TOOLTIP">
            <Original>Server-global upper bound for each roll stability vertical correction per update.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_STABILITY_ENABLED">
            <Original>Enable roll stability</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_STABILITY_ENABLED_TOOLTIP">
            <Original>Server-global roll and bank assist for eligible vehicles. It does not steer the vehicle.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_STRENGTH">
            <Original>Roll stability strength</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_ROLL_STRENGTH_TOOLTIP">
            <Original>Server-global vertical correction strength for roll and bank recovery. Higher values intervene harder.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_COAST_BREAKAWAY">
            <Original>Coast breakaway velocity</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_COAST_BREAKAWAY_TOOLTIP">
            <Original>Minimum downhill velocity nudge used near zero speed on slopes.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_DRIVE_ACCELERATION">
            <Original>Drive slope acceleration</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_DRIVE_ACCELERATION_TOOLTIP">
            <Original>How strongly slope angle adds powered downhill acceleration. Uphill deceleration remains controlled by Arma vehicle physics.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_DRIVE_MAX_SPEED">
            <Original>Drive assist max speed</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_DRIVE_MAX_SPEED_TOOLTIP">
            <Original>Maximum vehicle speed in kilometers per hour where downhill drive assist may add speed.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_MINIMUM">
            <Original>Minimum slope for rolling</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_MINIMUM_TOOLTIP">
            <Original>Terrain slope threshold before FIXICS disables idle autobrake or applies slope assist.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_ROLLBACK_ACCELERATION">
            <Original>Rollback acceleration</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_ROLLBACK_ACCELERATION_TOOLTIP">
            <Original>How strongly FIXICS accelerates unpowered vehicles downhill.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_ROLLBACK_MAX_SPEED">
            <Original>Rollback max speed</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_SLOPE_ROLLBACK_MAX_SPEED_TOOLTIP">
            <Original>Maximum assisted downhill coasting speed in meters per second.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_ACTIVATION_SPEED">
            <Original>Custom activation speed</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_ACTIVATION_SPEED_TOOLTIP">
            <Original>Server-global Custom speed in km/h before stability assistance may activate. Higher values leave low-speed sliding untouched. Custom values are ignored by fixed presets.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_ASSIST_COUNTERSTEER">
            <Original>Countersteering</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_ASSIST_MODE">
            <Original>Assistance mode</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_ASSIST_MODE_TOOLTIP">
            <Original>Server-global assistance mode for registered vehicles. Off uses passive handling only; stronger modes add bounded yaw, lateral, or countersteering recommendations.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_ASSIST_OFF">
            <Original>Off</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_ASSIST_YAW">
            <Original>Yaw damping</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_ASSIST_YAW_LATERAL">
            <Original>Yaw + lateral damping</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_COUNTERSTEER_STRENGTH">
            <Original>Custom countersteer strength</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_COUNTERSTEER_STRENGTH_TOOLTIP">
            <Original>Server-global Custom countersteering recommendation strength. Higher values react harder to spin, but can fight driver intent. Custom values are ignored by fixed presets.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_DEBUG_LOGGING">
            <Original>Stability debug logging</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_DEBUG_LOGGING_TOOLTIP">
            <Original>Server-global RPT diagnostics for registered vehicle stability assistance, including mode, slip, yaw, and bounded correction evidence.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_LATERAL_STRENGTH">
            <Original>Custom lateral strength</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_LATERAL_STRENGTH_TOOLTIP">
            <Original>Server-global Custom lateral velocity damping strength. Higher values reduce side-slip faster; too much can feel artificial. Custom values are ignored by fixed presets.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_MAXIMUM_CORRECTION">
            <Original>Custom maximum correction</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_MAXIMUM_CORRECTION_TOOLTIP">
            <Original>Server-global Custom upper bound for each stability correction per update. Lower values are smoother; higher values intervene more sharply. Custom values are ignored by fixed presets.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_PRESET">
            <Original>Stability preset</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_PRESET_CUSTOM">
            <Original>Custom</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_PRESET_RALLY">
            <Original>Rally</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_PRESET_REALISTIC_STABLE">
            <Original>Realistic Stable</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_PRESET_TOOLTIP">
            <Original>Server-global stability profile. Realistic Stable favors rollover control, Rally allows more slip, and Custom uses the sliders below. Only registered vehicles are eligible.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_SLIP_THRESHOLD">
            <Original>Custom slip threshold</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_SLIP_THRESHOLD_TOOLTIP">
            <Original>Server-global Custom lateral slip ratio required before assistance activates. Higher values allow wider slides before correction. Custom values are ignored by fixed presets.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_YAW_STRENGTH">
            <Original>Custom yaw strength</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STABILITY_YAW_STRENGTH_TOOLTIP">
            <Original>Server-global Custom yaw damping strength. Higher values reduce rotation faster during oversteer; too much may flatten natural slides. Custom values are ignored by fixed presets.</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STATIONARY_BRAKE_BYPASS">
            <Original>Stationary brake bypass speed</Original>
        </Key>
        <Key ID="STR_FIXICS_SETTING_STATIONARY_BRAKE_BYPASS_TOOLTIP">
            <Original>Speed below which brake/reverse input stops being treated as a persistent idle hold.</Original>
        </Key>
        <Key ID="STR_FIXICS_VR_CHAT">
            <Original>[FIXICS] Hello world from VR.</Original>
        </Key>
        <Key ID="STR_FIXICS_VR_HINT">
            <Original>Hello world from FIXICS in Virtual Reality.</Original>
        </Key>
        <Key ID="STR_FIXICS_VR_TITLE">
            <Original>Hello world in Virtual Reality</Original>
        </Key>
    </Package>
</Project>
