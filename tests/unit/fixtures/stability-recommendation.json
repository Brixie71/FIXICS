{
  "requiredSqfTokens": [
    "_activationSpeedKmh = (_activationSpeedKmh max 0) min 160;",
    "_slipThreshold = (_slipThreshold max 0) min 1;",
    "_yawStrength = (_yawStrength max 0) min 1;",
    "_lateralStrength = (_lateralStrength max 0) min 1;",
    "_countersteerStrength = (_countersteerStrength max 0) min 0.5;",
    "_maximumCorrection = (_maximumCorrection max 0) min 0.5;",
    "_deltaTime = (_deltaTime max 0) min 1;",
    "[false, 0, 0, 0, \"OFF\"]"
  ],
  "cases": [
    {
      "name": "off preserves motion",
      "input": {
        "mode": "OFF",
        "longitudinalSpeed": 20,
        "lateralSpeed": 5,
        "yawRate": 30,
        "steeringInput": 1,
        "deltaTime": 0.1,
        "profile": [true, 35, 0.12, 0.22, 0.12, 0.08, 0.12]
      },
      "expected": {
        "applied": false,
        "longitudinalSpeed": 20,
        "lateralSpeed": 5,
        "yawCorrection": 0,
        "mode": "OFF"
      }
    },
    {
      "name": "activation threshold preserves motion",
      "input": {
        "mode": "YAW",
        "longitudinalSpeed": 5,
        "lateralSpeed": 2,
        "yawRate": 10,
        "steeringInput": 1,
        "deltaTime": 0.1,
        "profile": [true, 35, 0.12, 0.22, 0.12, 0.08, 0.12]
      },
      "expected": {
        "applied": false,
        "longitudinalSpeed": 5,
        "lateralSpeed": 2,
        "yawCorrection": 0,
        "mode": "YAW"
      }
    },
    {
      "name": "slip threshold preserves motion",
      "input": {
        "mode": "YAW",
        "longitudinalSpeed": 20,
        "lateralSpeed": 1,
        "yawRate": 10,
        "steeringInput": 1,
        "deltaTime": 0.1,
        "profile": [true, 35, 0.12, 0.22, 0.12, 0.08, 0.12]
      },
      "expected": {
        "applied": false,
        "longitudinalSpeed": 20,
        "lateralSpeed": 1,
        "yawCorrection": 0,
        "mode": "YAW"
      }
    },
    {
      "name": "yaw mode clamps correction",
      "input": {
        "mode": "YAW",
        "longitudinalSpeed": 20,
        "lateralSpeed": 3,
        "yawRate": 10,
        "steeringInput": 1,
        "deltaTime": 0.1,
        "profile": [true, 35, 0.12, 0.22, 0.12, 0.08, 0.12]
      },
      "expected": {
        "applied": true,
        "longitudinalSpeed": 20,
        "lateralSpeed": 3,
        "yawCorrection": -0.12,
        "mode": "YAW"
      }
    },
    {
      "name": "yaw lateral mode damps lateral speed",
      "input": {
        "mode": "YAW_LATERAL",
        "longitudinalSpeed": 20,
        "lateralSpeed": 4,
        "yawRate": 2,
        "steeringInput": 1,
        "deltaTime": 0.5,
        "profile": [true, 35, 0.12, 0.22, 0.12, 0.08, 0.12]
      },
      "expected": {
        "applied": true,
        "longitudinalSpeed": 20,
        "lateralSpeed": 3.76,
        "yawCorrection": -0.12,
        "mode": "YAW_LATERAL"
      }
    },
    {
      "name": "countersteer mode returns bounded recommendation",
      "input": {
        "mode": "COUNTERSTEER",
        "longitudinalSpeed": 20,
        "lateralSpeed": 3,
        "yawRate": 10,
        "steeringInput": -1,
        "deltaTime": 0.1,
        "profile": [true, 35, 0.12, 0.22, 0.12, 0.08, 0.12]
      },
      "expected": {
        "applied": true,
        "longitudinalSpeed": 20,
        "lateralSpeed": 3,
        "yawCorrection": -0.08,
        "mode": "COUNTERSTEER"
      }
    },
    {
      "name": "profile and delta values are clamped",
      "input": {
        "mode": "YAW",
        "longitudinalSpeed": 1,
        "lateralSpeed": 1,
        "yawRate": 100,
        "steeringInput": 3,
        "deltaTime": 2,
        "profile": [true, -20, -1, 5, 5, 5, 0.02]
      },
      "expected": {
        "applied": true,
        "longitudinalSpeed": 1,
        "lateralSpeed": 1,
        "yawCorrection": -0.02,
        "mode": "YAW"
      }
    },
    {
      "name": "non finite input is rejected",
      "input": {
        "mode": "YAW",
        "longitudinalSpeed": "NaN",
        "lateralSpeed": 3,
        "yawRate": 10,
        "steeringInput": 1,
        "deltaTime": 0.1,
        "profile": [true, 35, 0.12, 0.22, 0.12, 0.08, 0.12]
      },
      "expected": {
        "applied": false,
        "longitudinalSpeed": 0,
        "lateralSpeed": 0,
        "yawCorrection": 0,
        "mode": "OFF"
      }
    },
    {
      "name": "unsupported profile preserves motion",
      "input": {
        "mode": "YAW_LATERAL",
        "longitudinalSpeed": -20,
        "lateralSpeed": 4,
        "yawRate": -5,
        "steeringInput": -1,
        "deltaTime": 0.2,
        "profile": [false, 35, 0.12, 0.22, 0.12, 0.08, 0.12]
      },
      "expected": {
        "applied": false,
        "longitudinalSpeed": -20,
        "lateralSpeed": 4,
        "yawCorrection": 0,
        "mode": "YAW_LATERAL"
      }
    },
    {
      "name": "unknown mode normalizes to off",
      "input": {
        "mode": "INVALID",
        "longitudinalSpeed": -20,
        "lateralSpeed": 4,
        "yawRate": -5,
        "steeringInput": -1,
        "deltaTime": 0.2,
        "profile": [true, 35, 0.12, 0.22, 0.12, 0.08, 0.12]
      },
      "expected": {
        "applied": false,
        "longitudinalSpeed": -20,
        "lateralSpeed": 4,
        "yawCorrection": 0,
        "mode": "OFF"
      }
    }
  ]
}
